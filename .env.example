# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ympv
POSTGRES_USER=ympv
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── Backend ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme_use_a_very_long_random_string_minimum_32_chars

# APP_ENV=dev
FRONTEND_URL=http://localhost
# ADMIN_EMAIL=
# MUSIC_DIR=/data

# ─── SMTP (signup email verification) ────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=changeme
# SMTP_PASS=changeme
# SMTP_FROM=YoutubeVault <no-reply@youtubevault.mylan>

# ─── Last.fm (Discover section + per-user scrobbling) ─────────────────────────
# LASTFM_API_KEY=
# LASTFM_API_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────
# FRONTEND_PORT=80

# ─── docker-compose.prod.yml only (deploying published images, e.g. on OMV) ──
# GHCR_NAMESPACE=yourname/youtube-music-playlist-vault
# IMAGE_TAG=latest
