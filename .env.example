# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ympv
POSTGRES_USER=ympv
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── Backend ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme_use_a_very_long_random_string_minimum_32_chars

# The full URL users use to access the app (no trailing slash)
FRONTEND_URL=http://localhost

# Where MP3 files are stored inside the backend container (mapped via Docker volume)
# To use a specific host path (e.g. on a NAS / OpenMediaVault), change the volume
# in docker-compose.yml:  music_data → a bind mount pointing to your media folder.
# MUSIC_DIR=/data  ← default, no need to change

# ─── Optional ────────────────────────────────────────────────────────────────
# FRONTEND_PORT=80

# ─── docker-compose.prod.yml only (deploying published images, e.g. on OMV) ──
# "owner/repo" (lowercase) of this repo on GitHub — see the README's
# "Deploying published images" section
# GHCR_NAMESPACE=yourname/youtube-music-playlist-vault
# IMAGE_TAG=latest
