# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ympv
POSTGRES_USER=ympv
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── Backend ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme_use_a_very_long_random_string_minimum_32_chars

# Deployment tier: dev / staging / production. The demo account (demo@gmail.com)
# is only ever seeded when this is "dev" — leave unset (defaults to dev) for
# docker-compose.yml, set to "production" for docker-compose.prod.yml deployments.
# APP_ENV=dev

# The full URL users use to access the app (no trailing slash)
FRONTEND_URL=http://localhost

# Whichever account registers with this email is marked admin at creation time
# (not retroactive — set this before that account signs up)
# ADMIN_EMAIL=

# Where MP3 files are stored inside the backend container (mapped via Docker volume)
# To use a specific host path (e.g. on a NAS / OpenMediaVault), change the volume
# in docker-compose.yml:  music_data → a bind mount pointing to your media folder.
# MUSIC_DIR=/data  ← default, no need to change

# ─── SMTP (signup email verification) ────────────────────────────────────────
# Required for APP_ENV=staging/production — registration fails loudly without
# it, so nobody signs up to an account they can never verify. Not required for
# APP_ENV=dev: the verification link is just logged to the console instead.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=changeme
# SMTP_PASS=changeme
# SMTP_FROM=MusicVault <no-reply@youtubevault.mylan>

# ─── Optional ────────────────────────────────────────────────────────────────
# FRONTEND_PORT=80

# ─── docker-compose.prod.yml only (deploying published images, e.g. on OMV) ──
# "owner/repo" (lowercase) of this repo on GitHub — see the README's
# "Deploying published images" section
# GHCR_NAMESPACE=yourname/youtube-music-playlist-vault
# IMAGE_TAG=latest
