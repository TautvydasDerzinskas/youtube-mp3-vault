generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String     @id @default(uuid())
  email                     String     @unique
  passwordHash              String
  displayName               String
  language                  String     @default("en")
  emailVerified             Boolean    @default(false)
  emailVerificationToken    String?    @unique
  emailVerificationExpires  DateTime?
  pendingEmail              String?
  isAdmin                   Boolean    @default(false)
  isBanned                  Boolean    @default(false)
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  playlists                 Playlist[]

  @@map("users")
}

model Playlist {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeId    String
  title        String
  customName   String?
  thumbnailUrl String?
  videoCount   Int             @default(0)
  syncStatus   String          @default("idle")
  syncPaused   Boolean         @default(false)
  lastSyncedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  videos       PlaylistVideo[]

  @@unique([userId, youtubeId])
  @@map("playlists")
}

model PlaylistVideo {
  id             String     @id @default(uuid())
  playlistId     String
  playlist       Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  youtubeId      String
  title          String
  duration       Int?
  thumbnailUrl   String?
  position       Int
  isAvailable    Boolean    @default(true)
  // The uploading channel, captured at sync time — used as an artist fallback
  // when the title itself doesn't look like "Artist - Title" (see musicbrainz.ts).
  channelName    String?
  downloadStatus String     @default("pending")
  downloadError  String?
  mediaFileId    String?
  mediaFile      MediaFile? @relation(fields: [mediaFileId], references: [id], onDelete: Restrict)
  fileSize       Int?
  bitrate        Int?
  // Set once at row creation and never touched again — unlike createdAt (a general
  // audit column elsewhere in the app), this is specifically the "date added to
  // this library" used to order/filter entries independently of YouTube's mutable
  // playlist `position`.
  addedAt        DateTime   @default(now())
  // Best-effort MusicBrainz enrichment — looked up once (per video) in the
  // background during sync, gated on connectivity and never blocking downloads.
  artist         String?
  album          String?
  trackNumber    Int?
  // Sourced from local Essentia audio-content analysis (see audio-analysis/
  // and audioAnalysisWorker.ts), not MusicBrainz — MB's crowd-sourced genre
  // tags are missing for most non-mainstream recordings, audio analysis
  // works on every downloaded track regardless.
  genre          String?
  releaseYear    Int?
  mbRecordingId  String?
  metadataStatus String     @default("pending") // pending | found | not_found | error
  metadataFetchedAt DateTime?
  // Needs the actual downloaded audio (unlike metadataStatus above, which only
  // needs the title), so this only ever progresses once downloadStatus is
  // 'done' — see audioAnalysisWorker.ts.
  audioAnalysisStatus    String     @default("pending") // pending | done | error
  audioAnalysisFetchedAt DateTime?
  // Track-level mean-pooled embedding from the Discogs-EffNet audio model —
  // captured now, as a free byproduct of genre classification, so a future
  // similarity/recommendation feature doesn't need to re-analyze the whole
  // library from scratch. Raw float32 bytes (not JSON — a few KB instead of
  // ~20KB of text per track); no consumer yet.
  audioEmbedding Bytes?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([playlistId, youtubeId])
  @@index([playlistId, position])
  @@index([playlistId, downloadStatus])
  @@index([playlistId, artist])
  @@index([playlistId, genre])
  // Used by the standalone metadata worker's global (cross-playlist) queue query —
  // without this, "find the next pending video across every playlist" degrades to a
  // full table scan once a library gets into the tens of thousands of rows.
  @@index([metadataStatus, addedAt])
  // Same rationale, for the audio-analysis worker's equivalent global queue query.
  @@index([audioAnalysisStatus, addedAt])
  @@map("playlist_videos")
}

/// Single shared, content-addressed copy of a downloaded YouTube video's MP3,
/// keyed by youtubeId so the same video is stored once regardless of how many
/// playlists/users reference it. PlaylistVideo.mediaFileId's onDelete: Restrict
/// is what makes GC trivial — deleting a row here fails while any
/// PlaylistVideo still points to it, succeeds once nothing does.
model MediaFile {
  id        String          @id @default(uuid())
  youtubeId String          @unique
  filename  String
  fileSize  Int
  bitrate   Int?
  createdAt DateTime        @default(now())
  videos    PlaylistVideo[]

  @@map("media_files")
}
