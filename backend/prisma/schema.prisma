generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String     @id @default(uuid())
  email                    String     @unique
  passwordHash             String
  displayName              String
  language                 String     @default("en")
  emailVerified            Boolean    @default(false)
  emailVerificationToken   String?    @unique
  emailVerificationExpires DateTime?
  pendingEmail             String?
  isAdmin                  Boolean    @default(false)
  isBanned                 Boolean    @default(false)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  playlists                Playlist[]

  @@map("users")
}

model Playlist {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeId    String
  title        String
  customName   String?
  thumbnailUrl String?
  videoCount   Int             @default(0)
  syncStatus   String          @default("idle")
  syncPaused   Boolean         @default(false)
  lastSyncedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  videos       PlaylistVideo[]

  @@unique([userId, youtubeId])
  @@map("playlists")
}

model PlaylistVideo {
  id                     String     @id @default(uuid())
  playlistId             String
  playlist               Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  youtubeId              String
  title                  String
  duration               Int?
  thumbnailUrl           String?
  position               Int
  isAvailable            Boolean    @default(true)
  // The uploading channel, captured at sync time — used as an artist fallback
  // when the title itself doesn't look like "Artist - Title" (see musicbrainz.ts).
  channelName            String?
  downloadStatus         String     @default("pending")
  downloadError          String?
  mediaFileId            String?
  mediaFile              MediaFile? @relation(fields: [mediaFileId], references: [id], onDelete: Restrict)
  fileSize               Int?
  bitrate                Int?
  // Set once at row creation and never touched again — unlike createdAt (a general
  // audit column elsewhere in the app), this is specifically the "date added to
  // this library" used to order/filter entries independently of YouTube's mutable
  // playlist `position`.
  addedAt                DateTime   @default(now())
  // Best-effort MusicBrainz enrichment — looked up once (per video) in the
  // background during sync, gated on connectivity and never blocking downloads.
  artist                 String?
  album                  String?
  trackNumber            Int?
  // Sourced from local Essentia audio-content analysis (see audio-analysis/
  // and audioAnalysisWorker.ts), not MusicBrainz — MB's crowd-sourced genre
  // tags are missing for most non-mainstream recordings, audio analysis
  // works on every downloaded track regardless. An array, not a single
  // value: a broad genre like "Electronic" covers wildly different-sounding
  // music, so a track can carry more than one parent genre (a genuine
  // Electronic/Hip Hop hybrid, say) plus one specific style tag — see
  // audio-analysis/app.py for how the list is built. Empty, not null, when
  // nothing's been determined yet.
  genres                 String[]   @default([])
  releaseYear            Int?
  mbRecordingId          String?
  metadataStatus         String     @default("pending") // pending | found | not_found | error
  metadataFetchedAt      DateTime?
  // Needs the actual downloaded audio (unlike metadataStatus above, which only
  // needs the title), so this only ever progresses once downloadStatus is
  // 'done' — see audioAnalysisWorker.ts.
  audioAnalysisStatus    String     @default("pending") // pending | done | error
  audioAnalysisFetchedAt DateTime?
  // Track-level mean-pooled embedding from the Discogs-EffNet audio model —
  // captured now, as a free byproduct of genre classification, so a future
  // similarity/recommendation feature doesn't need to re-analyze the whole
  // library from scratch. Raw float32 bytes (not JSON — a few KB instead of
  // ~20KB of text per track); no consumer yet.
  audioEmbedding         Bytes?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@unique([playlistId, youtubeId])
  @@index([playlistId, position])
  @@index([playlistId, downloadStatus])
  @@index([playlistId, artist])
  // No index on genres: it's an array now (no plain btree equivalent to the
  // old single-value one), and genre filtering has only ever happened
  // client-side against an already-fetched video list — no backend query
  // filters or sorts by it, so there's nothing to speed up here.
  // Used by the standalone metadata worker's global (cross-playlist) queue query —
  // without this, "find the next pending video across every playlist" degrades to a
  // full table scan once a library gets into the tens of thousands of rows.
  @@index([metadataStatus, addedAt])
  // Same rationale, for the audio-analysis worker's equivalent global queue query.
  @@index([audioAnalysisStatus, addedAt])
  @@map("playlist_videos")
}

/// Singleton settings row (always id=1) — SMTP and Postgres connection values
/// that started life as env vars (see config.ts) but are now admin-editable
/// at runtime via /api/admin/settings, taking precedence over env from then
/// on. See services/settings.ts for the env-seeding-on-first-read and
/// services/prisma.ts for how a Postgres change is tested before it's ever
/// applied to the live connection.
model AppSettings {
  id Int @id @default(1)

  // Optional — a null host means "email verification is off"; see
  // services/mailer.ts and the register/resend/profile-update routes.
  smtpHost   String?
  smtpPort   Int     @default(587)
  smtpSecure Boolean @default(false)
  smtpUser   String?
  smtpPass   String?
  smtpFrom   String  @default("YoutubeVault <no-reply@localhost>")

  // Required — this app always needs *a* database; the admin UI only lets
  // you point at a different already-migrated one, never an empty value.
  postgresDb       String
  postgresUser     String
  postgresPassword String

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

/// Single shared, content-addressed copy of a downloaded YouTube video's MP3,
/// keyed by youtubeId so the same video is stored once regardless of how many
/// playlists/users reference it. PlaylistVideo.mediaFileId's onDelete: Restrict
/// is what makes GC trivial — deleting a row here fails while any
/// PlaylistVideo still points to it, succeeds once nothing does.
model MediaFile {
  id        String          @id @default(uuid())
  youtubeId String          @unique
  filename  String
  fileSize  Int
  bitrate   Int?
  createdAt DateTime        @default(now())
  videos    PlaylistVideo[]

  @@map("media_files")
}
