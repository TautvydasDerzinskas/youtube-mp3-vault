# Copy to .env only if you need to override the server-address setup screen
# (see src/config.ts / src/screens/ServerSetupScreen.tsx). Normal use needs
# no .env at all — the app asks for and saves the server address on first
# launch. This override is a local-dev convenience: when set, that screen is
# skipped entirely and the app always points at this fixed backend instead
# of whatever's saved on-device.

# --- Local development alternatives ---
# Point at a backend run directly on your dev machine instead of the LAN
# instance:
#
#   Android emulator (10.0.2.2 reaches the host machine's localhost):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api
#
#   Physical device (use the host machine's real LAN IP instead):
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3001/api
