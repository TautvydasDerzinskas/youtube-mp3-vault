# Copy to .env only if you need to override the default (see src/config.ts) —
# the app already defaults to the self-hosted instance's LAN address,
# https://youtubevault.mylan, resolved by the router's local DNS. No .env is
# needed for normal use.

# --- Local development alternatives ---
# Point at a backend run directly on your dev machine instead of the LAN
# instance:
#
#   Android emulator (10.0.2.2 reaches the host machine's localhost):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api
#
#   Physical device (use the host machine's real LAN IP instead):
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3001/api
